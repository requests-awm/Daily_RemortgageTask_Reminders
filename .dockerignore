# Keep secrets and junk out of every build context / image.
node_modules
dist
.git
.gitignore

# Secrets — must never enter an image. Only *.example templates are allowed.
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example

# Logs / OS cruft
*.log
.DS_Store

# Docker meta
Dockerfile*
docker-compose*.yml
.dockerignore
