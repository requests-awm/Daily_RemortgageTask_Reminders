# Frontend: build the Vite SPA, then serve the static bundle with nginx.
# Vite inlines VITE_* at BUILD time, so mock/live is chosen here via build args.
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

# Default = safe mock demo (no backend needed). For live mode, build with:
#   --build-arg VITE_USE_MOCK=false --build-arg VITE_API_BASE_URL=http://localhost:8787
ARG VITE_USE_MOCK=true
ARG VITE_API_BASE_URL=
ENV VITE_USE_MOCK=$VITE_USE_MOCK
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

FROM nginx:alpine AS serve
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
