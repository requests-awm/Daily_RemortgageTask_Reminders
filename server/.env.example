# ─────────────────────────────────────────────────────────────
# BACKEND SERVICE — SECRETS. Never imported by the Vite frontend.
# Copy to server/.env (gitignored) and fill in real values there.
# NEVER commit real secrets into this template — placeholders only.
# Rotate any key that was ever committed; treat it as leaked.
# ─────────────────────────────────────────────────────────────

# --- Asana (task pull + comment posting) ---
ASANA_ACCESS_TOKEN=your-asana-personal-access-token
ASANA_PROJECT_ID=your-asana-project-gid
ASANA_WORKSPACE_ID=your-asana-workspace-gid

# --- Insightly (client email lookup by CONTACT_ID) ---
INSIGHTLY_API_KEY=your-insightly-api-key
INSIGHTLY_API_URL=https://api.na1.insightly.com/v3.1

# --- Gmail / Google OAuth (send as the mortgages mailbox) ---
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
MAIL_FROM_NAME=mortgages@ascotwm.com
MAIL_FROM_ADDRESS=requests@ascotwm.com
MAIL_REPLY_TO=mortgages@ascotwm.com
MAIL_BCC=jody.moses@ascotwm.com

# --- API hardening (production) ---
# Server port (platforms like Render/Railway inject this automatically).
PORT=8787
# Comma-separated browser origins allowed via CORS, or * for any (default).
# In production set this to your frontend URL, e.g. https://app.ascotwm.com
CORS_ALLOWED_ORIGINS=*
# Optional bearer token required on POST /api/send and /api/run/now. Blank = off.
# Do NOT put this in the frontend bundle — it's for trusted/server callers only.
API_TOKEN=

# --- Supabase (queue + audit tables) ---
# SERVICE-ROLE key is server-only: full DB access, bypasses RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Scheduler ---
# Cron for the daily run (08:30 Europe/London). Weekends: yes per the Zap.
RUN_CRON=30 8 * * *
RUN_TIMEZONE=Europe/London
RUN_WEEKENDS=yes

# --- Notifications ---
# Email a summary of HELD reminders to this address after each run.
# Blank = off (just logged). This is an internal ops email, not a client send.
NOTIFY_EMAIL=
APP_URL=http://localhost:5173

# --- Sending (SAFETY) ---
# 'dry' = resolve + log only, send nothing (DEFAULT). 'live' = actually send.
SEND_MODE=dry
# Auto-send policy: 'clean' = auto-send no-blocker reminders, hold the rest;
# 'off' = nothing auto-sends (everything waits in Awaiting Review).
AUTO_SEND=clean
# Optional: route ALL emails to this address for testing. Blank = real clients.
SEND_REDIRECT_TO=
# 'true' (DEFAULT) = only the test contacts in src/data/testContacts.js may be
# emailed; every other recipient is refused. Set 'false' to allow real clients.
TEST_RECIPIENTS_ONLY=true

# --- Twilio (SMS — reserved, not wired into the send path yet) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-from-number
