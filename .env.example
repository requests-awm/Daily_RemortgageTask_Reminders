# ─────────────────────────────────────────────────────────────
# FRONTEND (Vite) — CLIENT-SAFE VALUES ONLY
# Everything here is bundled into the browser build and is visible
# to anyone who opens the app. NEVER put API secrets, service-role
# keys, or the Asana / Insightly / Gmail tokens in this file.
# Secrets live in server/.env (see server/.env.example).
# ─────────────────────────────────────────────────────────────

# Data layer toggle: true = in-memory mock (default), false = live backend.
VITE_USE_MOCK=true

# Supabase — PUBLIC anon key only (protected by RLS). Safe in the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base URL of the backend service that holds the secrets and does the sending.
VITE_API_BASE_URL=http://localhost:8787
